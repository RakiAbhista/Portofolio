generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Profile {
  id          Int      @id @default(1)
  name        String
  title       String
  description String
  aboutText   String
}

model Skill {
  id   Int     @id @default(autoincrement())
  name String
  icon String?
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  preview     String?
  techStack   String   // comma separated
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
}

model Certificate {
  id            Int      @id @default(autoincrement())
  title         String
  issuer        String
  date          DateTime
  credentialUrl String?
  preview       String?
}

model SocialLink {
  id    Int    @id @default(autoincrement())
  name  String
  icon  String
  url   String
}
